{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "site start",
      "type": "node",
      "request": "launch",
      "cwd": "/workspace/.dinghy/site",
      "runtimeExecutable": "yarn",
      "runtimeArgs": [
        "docusaurus",
        "start",
        "--host",
        "0.0.0.0",
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "site build",
      "type": "node",
      "request": "launch",
      "cwd": "/workspace/.dinghy/site",
      "runtimeExecutable": "yarn",
      "runtimeArgs": [
        "docusaurus",
        "build",
        "--out-dir",
        "/workspace/.dinghy/site/output/site",
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "site serve",
      "type": "node",
      "request": "launch",
      "cwd": "/workspace/.dinghy/site",
      "runtimeExecutable": "yarn",
      "runtimeArgs": [
        "docusaurus",
        "serve",
        "--host",
        "0.0.0.0",
        "--dir",
        "/workspace/.dinghy/site/output/site",
      ],
      "console": "integratedTerminal"
    },
  ]
}